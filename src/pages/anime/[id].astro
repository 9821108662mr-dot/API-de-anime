---
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

let anime: any = null;
let error: string | null = null;

try {
  const res = await fetch(`https://api.jikan.moe/v4/anime/${id}/full`);
  if (!res.ok) {
    throw new Error('No se pudo encontrar este anime');
  }
  const data = await res.json();
  anime = data.data;
} catch (e: any) {
  error = e.message;
}

const formatDate = (dateString: string) => {
  if (!dateString) return 'Desconocida';
  return new Date(dateString).toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<Layout title={anime ? `${anime.title} - Detalles` : 'Anime No Encontrado'}>
  <div class="container">
    <a href="/" class="back-btn">← Volver al inicio</a>

    {error ? (
      <div class="error-state">
        <h2>{error}</h2>
      </div>
    ) : !anime ? (
      <div class="error-state">
        <h2>Cargando...</h2>
      </div>
    ) : (
      <>
        <div class="anime-header">
          <div class="anime-cover">
            <img src={anime.images.jpg.large_image_url} alt={anime.title} />
          </div>
          <div class="anime-details">
            <h1>{anime.title}</h1>
            <h2>{anime.title_japanese}</h2>

            <div class="tags">
              {anime.genres.map((genre: any) => (
                <span class="tag">{genre.name}</span>
              ))}
            </div>

            <div class="stats-grid">
              <div class="stat-box">
                <span class="label">Puntuación</span>
                <span class="value">⭐ {anime.score || 'N/A'}</span>
              </div>
              <div class="stat-box">
                <span class="label">Rango</span>
                <span class="value">#{anime.rank || 'N/A'}</span>
              </div>
              <div class="stat-box">
                <span class="label">Episodios</span>
                <span class="value">{anime.episodes || 'Desconocido'}</span>
              </div>
              <div class="stat-box">
                <span class="label">Estado</span>
                <span class="value">{anime.status}</span>
              </div>
              <div class="stat-box">
                <span class="label">Emisión</span>
                <span class="value">{formatDate(anime.aired.from)}</span>
              </div>
            </div>
          </div>
        </div>

        <div class="synopsis-box">
          <h3>Sinopsis</h3>
          <p>{anime.synopsis || 'No hay sinopsis disponible.'}</p>
        </div>

        {anime.trailer.youtube_id && (
          <div class="trailer-box">
            <h3>Tráiler Oficial</h3>
            <div class="video-responsive">
              <iframe 
                src={`https://www.youtube.com/embed/${anime.trailer.youtube_id}`} 
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen>
              </iframe>
            </div>
          </div>
        )}
      </>
    )}
  </div>
</Layout>

<style>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }
  .back-btn {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--btn-bg);
    text-decoration: none;
    font-weight: 600;
  }
  .back-btn:hover {
    text-decoration: underline;
  }
  
  .error-state {
    text-align: center;
    padding: 3rem;
    color: #e74c3c;
    font-size: 1.2rem;
  }

  .anime-header {
    display: flex;
    gap: 2rem;
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .anime-header {
      flex-direction: column;
    }
  }

  .anime-cover {
    flex-shrink: 0;
    width: 300px;
  }
  .anime-cover img {
    width: 100%;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }

  .anime-details h1 {
    margin: 0 0 0.5rem 0;
    font-size: 2.5rem;
    color: var(--text-color);
  }
  .anime-details h2 {
    margin: 0 0 1.5rem 0;
    font-size: 1.2rem;
    color: var(--secondary-text);
    font-weight: 400;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-box {
    background: var(--bg-color);
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    border: 1px solid var(--border-color);
  }
  .stat-box .label {
    display: block;
    font-size: 0.8rem;
    color: var(--secondary-text);
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }
  .stat-box .value {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-color);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .tag {
    background: var(--btn-bg);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.9rem;
  }

  .synopsis-box {
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    margin-bottom: 2rem;
  }
  .synopsis-box h3 {
    margin-top: 0;
    color: var(--text-color);
  }
  .synopsis-box p {
    line-height: 1.6;
    color: var(--text-color);
  }

  .trailer-box {
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    margin-bottom: 4rem;
  }
  .trailer-box h3 {
    margin-top: 0;
    color: var(--text-color);
  }
  .video-responsive {
    overflow: hidden;
    padding-bottom: 56.25%; /* 16:9 */
    position: relative;
    height: 0;
    border-radius: 8px;
  }
  .video-responsive iframe {
    left: 0;
    top: 0;
    height: 100%;
    width: 100%;
    position: absolute;
    border: none;
  }
</style>
