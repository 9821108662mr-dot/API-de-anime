---
export interface Props {
  id: number;
  title: string;
  imageUrl: string;
  score: number;
  synopsis: string;
}

const { id, title, imageUrl, score, synopsis } = Astro.props;
---
<a href={`/anime/${id}`} class="anime-card-link">
  <div class="anime-card">
    <img src={imageUrl} alt={title} class="anime-img">
    <div class="anime-info">
    <h3>{title}</h3>
    <p class="score">⭐ {score}</p>
    <p class="synopsis">{synopsis ? synopsis.substring(0, 100) + '...' : 'Sin sinopsis disponible'}</p>
  </div>
  </div>
</a>

<style>
  .anime-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
  }

  .anime-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .anime-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px rgba(0,0,0,0.2);
  }

  .anime-img {
    width: 100%;
    height: 350px;
    object-fit: cover;
  }

  .anime-info {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .anime-info h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.2rem;
    color: #2c3e50;
  }

  .score {
    font-weight: bold;
    color: #f39c12;
    margin-bottom: 0.5rem;
  }

  .synopsis {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.4;
    margin: 0;
  }
</style>
